# 服务端口
PORT=3000

# 环境: development | production | test
NODE_ENV=development

# 允许的前端域名（CORS），逗号分隔
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-username.github.io

# ===== 数据库配置 =====
# DB_TYPE=memory  使用内存存储（默认，无需安装 MySQL）
# DB_TYPE=mysql   使用 MySQL 数据库
DB_TYPE=memory
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=baobeileiting

# ===== JWT 配置（Phase 1 启用） =====
# ⚠️ 生产环境必须设置为高强度随机密钥（至少 256 位熵）
#     开发环境可使用默认密钥，生产环境使用默认密钥将导致启动报错
# JWT_SECRET=your-jwt-secret-change-in-production
# JWT_EXPIRES_IN=7d

# ===== 认证模式（仅 development 生效） =====
# development + false → x-user-id 测试模式（无需 token）
# development + true  → JWT 认证
# production → 永远 JWT 认证，忽略此配置
AUTH_ENABLED=false
