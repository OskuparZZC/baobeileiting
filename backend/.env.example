# 服务端口
PORT=3000

# 环境: development | production | test
NODE_ENV=development

# 允许的前端域名（CORS），逗号分隔
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-username.github.io

# ===== 数据库配置（Phase 6 启用） =====
# DB_TYPE=mysql
# DB_HOST=your-tencent-cloud-mysql-host
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password
# DB_NAME=baobeileiting

# ===== JWT 配置（Phase 1 启用） =====
# JWT_SECRET=your-jwt-secret-change-in-production
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d
